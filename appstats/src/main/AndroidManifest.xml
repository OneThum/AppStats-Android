<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application>
        <!--
            Opt-in auto-initialization via androidx.startup. Consumers can either:
            (a) call AppStats.configure(...) manually from Application.onCreate()
            (b) declare a <meta-data android:name="com.onethumsoftware.appstats.API_KEY" .../>
                in their app manifest and have AppStatsInitializer pick it up.
            We declare the initializer here but it requires manifest meta-data in the
            host app to actually configure the SDK, so the default behavior is
            "do nothing" if the consumer does not opt in.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="com.onethumsoftware.appstats.AppStatsInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>
</manifest>
